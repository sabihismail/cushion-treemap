{
  "name": "cushion-treemap",
  "version": "0.1.0",
  "description": "Zero-dependency, framework-agnostic cushion treemap for HTML canvas, with a built-in switchable theme system (Catppuccin, Nord, Tokyo Night, Rosé Pine, Carbon, Tailwind).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "demo": "vite",
    "demo:build": "node scripts/build-demo.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/units.test.ts",
    "test:vitest": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "treemap",
    "cushion-treemap",
    "canvas",
    "visualization",
    "dataviz",
    "disk-usage",
    "squarify",
    "themes"
  ],
  "author": "Sabih Ismail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabihismail/cushion-treemap.git"
  },
  "homepage": "https://github.com/sabihismail/cushion-treemap#readme",
  "bugs": {
    "url": "https://github.com/sabihismail/cushion-treemap/issues"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.8",
    "canvas": "^3.2.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.2.0",
    "vitest": "^4.1.8"
  }
}
